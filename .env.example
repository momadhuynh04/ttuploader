# Api v3 for check youtube channel and video 
GOOGLE_API_KEY=""
# Youtube channel url (e.g 'https://www.youtube.com/@channel/shorts')
CHANNEL_ID=""
# Youtube cookie file path (if empty, pass) for ytdlp download (e.g 'youtube_cookies.txt')
YT_COOKIE_FILE=""
# Skip video if duration is more than specified (seconds)
SKIP_VIDEO_IF_DURATION_MORE_THAN=300
# Skip video if duration is less than specified (seconds)
SKIP_VIDEO_IF_DURATION_LESS_THAN=0

# Checking interval for new video (seconds) - YouTube API free quota: 100 units/search, 10000/day
# Recommend 30-60 min minimum to avoid quota exhaustion
MINIMUM_CHECK_INTERVAL=1800
MAXIMUM_CHECK_INTERVAL=3600

# Proxy for browser automation(if empty, pass)
PROXY=""

# Render strategy for browser automation (default: 'stealth', options: 'none', 'stealth', 'loop', 'transform')
# Audio render strategy for browser automation (default: 'pitch_speedshift', options: 'none', 'pitch_speedshift', 'enhanced_pitch', 're_encode', 'audio_mix', 'full_replace', 'no_sound')
RENDER_STRATEGY="stealth"
AUDIO_RENDER_STRATEGY="pitch_speedshift"
# Minimum video duration for render (seconds)
MINIMUM_VIDEO_DURATION=0

# Tik Tok account region (default: 'US', options: 'US', 'JP', 'KR', 'VN', 'BR', 'IT', 'FR', 'DE', 'ES')
# Automation language based on region: US=English, JP=日本語, KR=한국어, VN=Tiếng Việt, BR=Português, IT=Italiano, FR=Français, DE=Deutsch, ES=Español
TIKTOK_REGION=""

# Tik Tok cookie file (export JSON from browser extension like EditThisCookie, place in project root)
TIKTOK_COOKIE_FILE="tiktok_cookies.json"

# Discord webhook url for notification (if empty, pass)
DISCORD_WEBHOOK_URL=""

# Fallback caption for video (if fail extract caption from youtube video, use this caption instead)
FALLBACK_CAPTION=""
FALLBACK_HASHTAGS="#viral #trending #fyp #foryou #foryoupage #explore #explorepage #tiktok #tiktokviral #tiktoktrend #tiktoktrending"
